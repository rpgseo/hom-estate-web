---
import BaseLayout from '../layouts/BaseLayout.astro'
import PhotoLightbox from './PhotoLightbox.jsx'
import '../pages/pages.css'
import './ColivingDetail.css'

const { coliving } = Astro.props

const GALLERY_IMAGES = coliving.gallery?.length > 0
  ? coliving.gallery
  : [
    'https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=800&fm=webp',
    'https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?w=800&fm=webp',
    'https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=800&fm=webp',
    'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&fm=webp',
    'https://images.unsplash.com/photo-1493809842364-78817add7ffb?w=800&fm=webp',
  ]

import { marked } from 'marked'

const rooms = coliving.rooms || []
const features = coliving.features || []
const pricingPlans = coliving.pricingPlans || []
// Split features: first 4 are structural specs (Salon, Dormitorios, Banos, Garaje)
// shown as quick-specs; the rest are amenity-style, shown only in sidebar
const structuralFeatures = features.slice(0, 4)
const amenityFeatures = features.slice(4)
const heroImage = coliving.image || GALLERY_IMAGES[0]
const rawDescription = coliving.description || `Disfruta de una experiencia de coliving unica en ${coliving.location}. Nuestros espacios estan disenados para ofrecer comodidad, comunidad y flexibilidad. Habitaciones completamente amuebladas con todos los servicios incluidos.`

// Strip sections that are shown elsewhere (sidebar features, vecindario accordion)
// Extract vecindario section for the accordion
const vecindarioMatch = rawDescription.match(/#+\s*Vecindario\s*\n([\s\S]*?)(?=\n#+\s|$)/i)
const vecindarioHtml = vecindarioMatch ? marked.parse(vecindarioMatch[1].trim()) : ''

// Strip sections that are shown elsewhere (sidebar features, vecindario accordion)
const strippedDescription = rawDescription
  .replace(/#+\s*Informacion del Coliving y comodidades[\s\S]*?(?=\n#+\s|\n\n[A-Z])/i, '')
  .replace(/#+\s*Vecindario[\s\S]*?(?=\n#+\s|$)/i, '')
  .replace(/\n{3,}/g, '\n\n')
  .trim()

let description = marked.parse(strippedDescription) as string

// Post-process markdown HTML for richer visual presentation
// 1) Tag plan paragraphs: <p><strong>X</strong> — desc</p> -> plan card (short bold title with em-dash)
description = description.replace(
  /<p><strong>([^<:]{3,30})<\/strong>\s*[—–-]\s*([\s\S]*?)<\/p>/g,
  '<!--PLAN--><div class="cd-plan-card"><h4 class="cd-plan-title">$1</h4><p>$2</p></div>'
)
// Wrap consecutive plan cards into a grid row
description = description.replace(
  /(?:<!--PLAN--><div class="cd-plan-card">[\s\S]*?<\/div>\s*){2,}/g,
  (match) => `<div class="cd-plans-row">${match.replace(/<!--PLAN-->/g, '')}</div>`
)
description = description.replace(/<!--PLAN-->/g, '')

// 2) "Importante:" paragraph -> info callout
description = description.replace(
  /<p><strong>(Importante[:\s]*)<\/strong>\s*([\s\S]*?)<\/p>/gi,
  '<aside class="cd-callout cd-callout--info"><div class="cd-callout-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg></div><div class="cd-callout-body"><strong>$1</strong> $2</div></aside>'
)

// 3) Paragraph starting with "(*)" -> warning callout
description = description.replace(
  /<p>\s*\(\*\)\s*([\s\S]*?)<\/p>/gi,
  '<aside class="cd-callout cd-callout--warning"><div class="cd-callout-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg></div><div class="cd-callout-body">$1</div></aside>'
)

// 4) "Incluimos" list (short items) -> chip list
description = description.replace(
  /(<h[234][^>]*>\s*Incluimos\s*<\/h[234]>\s*)<ul>/i,
  '$1<ul class="cd-chip-list">'
)

---

<BaseLayout
  title={coliving.seoTitle || `${coliving.name} | HOM.ESTATE`}
  description={coliving.seoDescription || coliving.tagline}
>
  <!-- HERO SECTION -->
  <section class="cd-hero">
    <div class="cd-hero-container">
      <!-- Header -->
      <div class="cd-hero-header">
        <div class="cd-hero-header-left">
          <nav class="cd-breadcrumb">
            <a href="/">Inicio</a>
            <span>&gt;</span>
            <a href={`/gestion-alquiler-habitaciones-${coliving.city?.slug || 'zaragoza'}`}>{coliving.city?.name || 'Zaragoza'}</a>
            <span>&gt;</span>
            <span>{coliving.name}</span>
          </nav>
          <h1 class="cd-hero-title">{coliving.name}</h1>
          <p class="cd-hero-location">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            {coliving.location}
          </p>
        </div>
      </div>

      <!-- Photo grid with lightbox -->
      <PhotoLightbox images={[heroImage, ...GALLERY_IMAGES]} altPrefix={coliving.name} client:visible />
    </div>
  </section>

  <!-- QUICK TAGS BAR (idealista style) -->
  <section class="cd-tags">
    <div class="cd-tags-container">
      <button class="cd-tag" id="cd-tag-fotos" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        <span class="cd-tag-label">{GALLERY_IMAGES.length} fotos</span>
      </button>
      <button class="cd-tag" id="cd-tag-plano" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3v18"/><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M21 9H3"/><path d="M21 15H3"/></svg>
        <span class="cd-tag-label">Plano</span>
      </button>
      <button class="cd-tag" id="cd-tag-video" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m16 13 5.223 3.482a.5.5 0 0 0 .777-.416V7.934a.5.5 0 0 0-.777-.416L16 11"/><rect width="14" height="12" x="2" y="6" rx="2"/></svg>
        <span class="cd-tag-label">Video</span>
      </button>
      <a class="cd-tag" href="#mapa">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        <span class="cd-tag-label">Mapa</span>
      </a>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <section class="cd-content">
    <div class="cd-content-container">
      <div class="cd-main">
        <!-- Tagline + Quick specs -->
        <div class="cd-section cd-section--intro" data-animate>
          {structuralFeatures.length > 0 && (
            <ul class="cd-spec-chips">
              {structuralFeatures.map((f) => {
                const label = (f.label || '').toLowerCase()
                let iconPath = 'M12 2 L12 22 M2 12 L22 12'
                if (/salon|cocina/.test(label))
                  iconPath = 'M3 7h18M3 12h18M3 17h18'
                else if (/dormitorio|habitac|cama/.test(label))
                  iconPath = 'M2 9v12h20V9M6 9V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v4M2 14h20'
                else if (/bano|baño|ducha/.test(label))
                  iconPath = 'M9 6V4a2 2 0 0 1 4 0v2M4 10h16v5a5 5 0 0 1-5 5H9a5 5 0 0 1-5-5zM6 20l-1 2M18 20l1 2'
                else if (/garaje|parking|coche/.test(label))
                  iconPath = 'M5 17v-5l2-5h10l2 5v5M5 17h14M7 17v2M17 17v2M8 12h8'
                return (
                  <li class="cd-spec-chip">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d={iconPath}/></svg>
                    <span>{f.label}</span>
                  </li>
                )
              })}
            </ul>
          )}
          <h2 class="cd-section-title cd-section-title--hero">{coliving.tagline || coliving.name}</h2>
        </div>

        <!-- Full description from Strapi (rich text with all property info) -->
        <div class="cd-section cd-section--description" data-animate>
          <div class="cd-description" set:html={description} />
        </div>

        <!-- Map -->
        <div class="cd-section" id="mapa" data-animate>
          <h2 class="cd-section-title">Ubicacion</h2>
          <p class="cd-map-location">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            {coliving.location}
          </p>
          <div class="cd-map-container">
            <iframe
              src={`https://www.openstreetmap.org/export/embed.html?bbox=-0.9200,41.6300,-0.8400,41.6800&layer=mapnik&marker=41.6560,-0.8773`}
              width="100%"
              height="350"
              style="border: 0; border-radius: 12px;"
              loading="lazy"
              title={`Mapa de ${coliving.location}`}
            ></iframe>
          </div>
        </div>

        <!-- Vecindario accordion -->
        {vecindarioHtml && (
          <div class="cd-section" data-animate>
            <details class="cd-accordion">
              <summary class="cd-accordion-trigger">
                <h2 class="cd-section-title">Vecindario</h2>
                <svg class="cd-accordion-chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </summary>
              <div class="cd-accordion-body cd-description" set:html={vecindarioHtml} />
            </details>
          </div>
        )}

      </div>

      <!-- SIDEBAR -->
      <aside class="cd-sidebar">
        <div class="cd-sidebar-card cd-sidebar-card--sticky" data-animate="slide-left">
          <!-- Structural specs (compact) -->
          {structuralFeatures.length > 0 && (
            <ul class="cd-sidebar-features">
              {structuralFeatures.map((f) => (
                <li>{f.label}</li>
              ))}
            </ul>
          )}

          <!-- Price + Availability header -->
          {coliving.priceFrom && (
            <div class="cd-sidebar-price-row">
              <div class="cd-sidebar-price">
                <span class="cd-sidebar-price-desde">Desde</span>
                <strong>{coliving.priceFrom}&euro;</strong>
                <span>/mes</span>
              </div>
              <div class="cd-sidebar-avail">
                <span class="cd-sidebar-avail-label">Disponible desde</span>
                <strong>Ahora</strong>
              </div>
            </div>
          )}

          <!-- CTA -->
          <a href="tel:+34636155847" class="cd-btn cd-btn--green cd-btn--full">Contactar</a>

          <!-- Comes with / Que incluye -->
          <h4 class="cd-sidebar-section-title">Que incluye</h4>
          <div class="cd-sidebar-icons-grid">
            <div class="cd-sidebar-icon-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <span>Limpieza semanal</span>
            </div>
            <div class="cd-sidebar-icon-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 11h.01"/><path d="M11 15h.01"/><path d="M16 16h.01"/><path d="m2 16 20 6-6-20A20 20 0 0 0 2 16"/><path d="M5.71 17.11a17.04 17.04 0 0 1 11.4-11.4"/></svg>
              <span>Cocina equipada</span>
            </div>
            <div class="cd-sidebar-icon-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              <span>Suministros incluidos</span>
            </div>
            <div class="cd-sidebar-icon-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 13a10 10 0 0 1 14 0"/><path d="M8.5 16.5a5 5 0 0 1 7 0"/><path d="M2 8.82a15 15 0 0 1 20 0"/><line x1="12" x2="12.01" y1="20" y2="20"/></svg>
              <span>WiFi alta velocidad</span>
            </div>
            <div class="cd-sidebar-icon-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
              <span>Mantenimiento</span>
            </div>
            <div class="cd-sidebar-icon-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 11h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-5Zm0 0a9 9 0 1 1 18 0m0 0v5a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3Z"/></svg>
              <span>Asistencia 24h</span>
            </div>
            <div class="cd-sidebar-icon-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span>Cerradura privada</span>
            </div>
            <div class="cd-sidebar-icon-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v20"/><path d="M2 12h20"/><path d="m4.93 4.93 14.14 14.14"/><path d="m19.07 4.93-14.14 14.14"/></svg>
              <span>Calefaccion</span>
            </div>
            <div class="cd-sidebar-icon-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/></svg>
              <span>Cama doble</span>
            </div>
            <div class="cd-sidebar-icon-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="20" height="20" x="2" y="2" rx="2"/><circle cx="12" cy="12" r="5"/><path d="M12 7v0"/></svg>
              <span>Lavanderia</span>
            </div>
            <div class="cd-sidebar-icon-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 9V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v3"/><path d="M2 11v5a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-5a2 2 0 0 0-4 0v2H6v-2a2 2 0 0 0-4 0Z"/><path d="M4 18v2"/><path d="M20 18v2"/><path d="M12 4v9"/></svg>
              <span>Amueblado</span>
            </div>
            <div class="cd-sidebar-icon-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span>Zonas comunes</span>
            </div>
          </div>

          <!-- Rooms list in sidebar -->
          {rooms.length > 0 && (
            <>
              <h4 class="cd-sidebar-section-title">Habitaciones</h4>
              <div class="cd-sidebar-rooms">
                {rooms.map((room) => (
                  <div class="cd-sidebar-room">
                    <div class="cd-sidebar-room-top">
                      <strong>{room.name}</strong>
                      <span class={`cd-room-status cd-room-status--${room.status}`}>
                        {room.status === 'available' ? 'Disponible' : room.status === 'occupied' ? 'Ocupado' : room.status === 'reserved' ? 'Reservado' : 'Mantenimiento'}
                      </span>
                    </div>
                    <div class="cd-sidebar-room-meta">
                      <span class="cd-room-type">{room.roomType}</span>
                    </div>
                    {pricingPlans.length > 0 && (
                      <div class="cd-room-plans">
                        <p class="cd-room-plans-label">Todo incluido! desde:</p>
                        <div class="cd-room-plans-grid">
                          {pricingPlans.map((plan, i) => (
                            <div class={`cd-room-plan ${i === pricingPlans.length - 1 ? 'cd-room-plan--best' : ''}`}>
                              <strong class="cd-room-plan-price">{plan.price}&euro;</strong>
                              <span class="cd-room-plan-name">{plan.name}</span>
                              {plan.tagline && <span class="cd-room-plan-save">{plan.tagline}</span>}
                            </div>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </>
          )}
        </div>
      </aside>
    </div>
  </section>


  <!-- CTA BOTTOM -->
  <section class="cd-cta">
    <div class="cd-cta-container" data-animate>
      <h2>Te interesa {coliving.name}?</h2>
      <p>Contacta con nosotros para conocer disponibilidad y agendar una visita.</p>
      <div class="cd-cta-buttons">
        <a href="tel:+34636155847" class="cd-btn cd-btn--yellow">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Llamar ahora
        </a>
        <a href="mailto:info@hom.estate" class="cd-btn cd-btn--outline">
          Enviar email
        </a>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Fotos tag → open lightbox at first image
      document.getElementById('cd-tag-fotos')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('open-lightbox', { detail: { index: 0 } }))
      })
      // Plano tag → open lightbox at first image (placeholder until floor plan images are separate)
      document.getElementById('cd-tag-plano')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('open-lightbox', { detail: { index: 0 } }))
      })
      // Video tag → open lightbox at first image (placeholder until video support)
      document.getElementById('cd-tag-video')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('open-lightbox', { detail: { index: 0 } }))
      })
    })
  </script>
</BaseLayout>
