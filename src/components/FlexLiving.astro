---
import '../components/FlexLiving.css'

const ADVANTAGES = [
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 18h1.4c1.3 0 2.5-.6 3.3-1.7l6.1-8.6c.7-1.1 2-1.7 3.3-1.7H22"/><path d="m18 2 4 4-4 4"/><path d="M2 6h1.9c1.5 0 2.9.9 3.6 2.2"/><path d="M22 18h-5.9c-1.3 0-2.6-.7-3.3-1.8l-.5-.8"/><path d="m18 14 4 4-4 4"/></svg>',
    title: 'Adaptabilidad',
    content: 'El Flex Living permite adaptarse a las circunstancias cambiantes de la vida. Ya sea un cambio de trabajo, una nueva relación o simplemente el deseo de explorar nuevos entornos, la flexibilidad en la vivienda ofrece la libertad de ajustarse sin los compromisos a largo plazo asociados con la compra de una propiedad.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>',
    title: 'Mayor movilidad',
    content: 'Para aquellos que valoran la movilidad geográfica, el Flex Living es ideal. Permite mudarse fácilmente entre ciudades o incluso países, facilitando la exploración de diferentes culturas y oportunidades sin las ataduras de una hipoteca.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/></svg>',
    title: 'Flexibilidad laboral',
    content: 'Con el auge del trabajo remoto y los empleos freelance, muchas personas buscan viviendas que se adapten a su estilo de trabajo flexible. El Flex Living ofrece espacios que pueden funcionar tanto como hogar como oficina.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 5c-1.5 0-2.8 1.4-3 2-3.5-1.5-11-.3-11 5 0 1.8 0 3 2 4.5V20h4v-2h3v2h4v-4c1-.5 1.7-1 2-2h2v-4h-2c0-1-.5-1.5-1-2"/><path d="M2 9v1c0 1.1.9 2 2 2h1"/><path d="M16 11h0"/></svg>',
    title: 'Reducción de costos',
    content: 'Al evitar la compra de una propiedad, se eliminan costos como el mantenimiento, impuestos de propiedad y seguros de hogar. Además, los alquileres flexibles suelen incluir servicios y mobiliario, lo que reduce los gastos adicionales.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>',
    title: 'Experiencias enriquecedoras',
    content: 'Vivir en diferentes lugares permite acumular experiencias diversas y enriquecedoras, conocer gente nueva y desarrollar una perspectiva más amplia del mundo.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
    title: 'Red de contactos y comunidad',
    content: 'Los espacios de Flex Living suelen fomentar la comunidad entre sus residentes, lo que facilita la creación de una red de contactos profesional y personal valiosa.',
  },
]
---

<section id="flex-living" class="flex-living-section">
  <div class="container">
    <div class="flex-living-header" data-animate>
      <h2 class="section-title">Flex Living</h2>
    </div>
    <p class="flex-living-subtitle" data-animate="fade" data-delay="2">
      Un estilo de vida
    </p>
    <p class="flex-living-description" data-animate data-delay="3">
      El concepto de Flex Living redefine la forma en que vivimos,
      ofreciendo soluciones de vivienda adaptables que se ajustan a tu
      ritmo de vida. Descubre las ventajas de un estilo de vida sin
      ataduras.
    </p>
  </div>

  <div class="advantages-grid">
    {ADVANTAGES.map((advantage, index) => (
      <div class="advantage-card" data-animate data-delay={index + 1}>
        <div class="advantage-header" role="button" tabindex="0" aria-expanded="false" data-accordion>
          <div class="advantage-header-left">
            <div class="advantage-icon" aria-hidden="true">
              <Fragment set:html={advantage.icon} />
            </div>
            <h3>{advantage.title}</h3>
          </div>
          <div class="advantage-toggle">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>
        </div>
        <div class="advantage-content" style="display:grid;grid-template-rows:0fr;transition:grid-template-rows 0.3s ease-in-out;overflow:hidden;">
          <div style="overflow:hidden;">
            <div class="advantage-content-inner">
              {advantage.content}
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  document.querySelectorAll('[data-accordion]').forEach((header) => {
    const toggle = () => {
      const card = header.closest('.advantage-card')
      const content = card.querySelector('.advantage-content')
      const toggleIcon = header.querySelector('.advantage-toggle')
      const isOpen = content.style.gridTemplateRows === '1fr'

      // Close all others
      document.querySelectorAll('.advantage-content').forEach((c) => {
        c.style.gridTemplateRows = '0fr'
      })
      document.querySelectorAll('.advantage-toggle').forEach((t) => {
        t.classList.remove('open')
      })
      document.querySelectorAll('[data-accordion]').forEach((h) => {
        h.setAttribute('aria-expanded', 'false')
      })

      if (!isOpen) {
        content.style.gridTemplateRows = '1fr'
        toggleIcon.classList.add('open')
        header.setAttribute('aria-expanded', 'true')
      }
    }

    header.addEventListener('click', toggle)
    header.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault()
        toggle()
      }
    })
  })
</script>
