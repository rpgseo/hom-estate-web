---
import '../components/Services.css'

const SERVICES = [
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>',
    title: 'House Flipping',
    description: 'Adquisición, reforma y venta de propiedades para maximizar el retorno de inversión.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="5.5"/><path d="m21 2-9.6 9.6"/><path d="m15.5 7.5 3 3L22 7l-3-3"/></svg>',
    title: 'Buy to Rent',
    description: 'Gestión experta en alquileres, incluyendo opciones de alquiler turístico, alquiler temporal (Flex Living) y alquiler habitual.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 2.1l4 4-4 4"/><path d="M3 12.2v-2a4 4 0 0 1 4-4h12.8M7 21.9l-4-4 4-4"/><path d="M21 11.8v2a4 4 0 0 1-4 4H4.2"/></svg>',
    title: 'Rent to Rent',
    description: 'Subarrendamiento de propiedades para maximizar ingresos pasivos.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>',
    title: 'Property Management',
    description: 'Administración completa de propiedades, garantizando eficiencia y rentabilidad.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>',
    title: 'Flex Living',
    description: 'Estilo de vida flexible adaptado a las necesidades cambiantes.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>',
    title: 'Consulting',
    description: 'Asesoramiento personalizado en inversión inmobiliaria.',
  },
]
---

<section id="servicios" class="services-section">
  <div class="container">
    <div class="services-header" data-animate>
      <h2 class="section-title">Nuestros Servicios</h2>
      <p class="section-subtitle">
        Soluciones integrales para maximizar el rendimiento de su inversión
        inmobiliaria.
      </p>
    </div>
  </div>

  <div class="services-grid">
    {SERVICES.map((service, index) => (
      <article class="service-card" data-animate data-delay={index + 1}>
        <span class="service-number">
          {String(index + 1).padStart(2, '0')}
        </span>
        <div class="service-icon" aria-hidden="true">
          <Fragment set:html={service.icon} />
        </div>
        <h3>{service.title}</h3>
        <p>{service.description}</p>
        <div class="service-accent"></div>
      </article>
    ))}
  </div>

  <div class="services-cta" data-animate>
    <p>
      Nos comprometemos a proporcionar soluciones personalizadas que se alineen
      con sus objetivos financieros y maximicen el rendimiento de sus inversiones.
      Contáctenos para descubrir cómo podemos maximizar su rentabilidad.
    </p>
    <a href="/consulting" class="services-cta-btn">Más información</a>
  </div>
</section>
