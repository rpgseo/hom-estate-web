---
import '../components/Hero.css'
import introVideo from '../assets/hom-estate-intro.webm'
---

<section id="inicio" class="hero-section">
  <div class="hero-frame">
    <!-- Video background -->
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
    >
      <source src={introVideo} type="video/webm" />
    </video>
    <div class="hero-video-overlay"></div>

    <!-- Content at bottom-left -->
    <div class="hero-content" style="animation: fadeUp 0.8s ease-out 0.4s both;">
      <span class="hero-tag" style="animation: fadeUp 0.6s ease-out 0.2s both;">
        ¡Únete al cambio!
      </span>

      <h1 class="hero-title" style="animation: fadeUp 0.7s ease-out 0.4s both;">
        Transformamos espacios,{' '}
        <span class="highlight">generamos valor.</span>
      </h1>

      <p class="hero-description" style="animation: fadeUp 0.6s ease-out 0.6s both;">
        Calidad para nuestros inquilinos, rentabilidad para nuestros inversores.
      </p>
    </div>

    <div class="hero-scroll-indicator" aria-hidden="true">
      <span>Scroll</span>
      <div class="hero-scroll-line"></div>
    </div>
  </div>
</section>

<!-- Tabs + Panels below hero -->
<div class="hero-panels">
  <div class="hero-tabs-bar" data-animate>
    <div class="hero-tabs">
      <div class="hero-tabs-slider"></div>
      <button class="hero-tab active" data-tab="inquilino">Inquilino</button>
      <button class="hero-tab" data-tab="inversor">Inversor</button>
    </div>
  </div>
  <div class="hero-panel active" id="panel-inquilino">
    <div class="panel-inner">
      <h2 class="panel-title" data-animate>Aumenta tu calidad de vida</h2>
      <p data-animate data-delay="1">
        Comprometidos con una vivienda de calidad. Nuestro objetivo es solucionar
        las necesidades del mercado ofertando viviendas dignas y de calidad que
        mejoren la vida de nuestros inquilinos.
      </p>
      <p data-animate data-delay="2">
        Nuestra orientación hacia la excelencia nos permite no solo ofrecer
        propiedades que cumplen con las expectativas de nuestros inquilinos,
        sino también estar maximizando la rentabilidad de nuestros propietarios.
      </p>
      <p class="panel-highlight" data-animate data-delay="3">
        Garantizamos que cada propiedad que transformamos sea una inversión exitosa.
      </p>
    </div>
  </div>

  <div class="hero-panel" id="panel-inversor">
    <div class="panel-inner">
      <span class="panel-tag" data-animate>Hom.estate</span>
      <h2 class="panel-title" data-animate data-delay="1">
        Inversión inmobiliaria <span class="highlight">inteligente.</span>
      </h2>
      <p data-animate data-delay="2">
        En Hom Estate, nos especializamos en optimizar el rendimiento de sus
        activos inmobiliarios a través de estrategias avanzadas y un enfoque
        integral.
      </p>
    </div>
  </div>
</div>

<script>
  const tabsContainer = document.querySelector('.hero-tabs')
  const tabs = document.querySelectorAll('.hero-tab')
  const slider = document.querySelector('.hero-tabs-slider')
  const panels = document.querySelectorAll('.hero-panel')

  function moveSlider(tab) {
    const containerRect = tabsContainer.getBoundingClientRect()
    const tabRect = tab.getBoundingClientRect()
    slider.style.width = tabRect.width + 'px'
    slider.style.left = (tabRect.left - containerRect.left) + 'px'
  }

  // Position slider on load
  const activeTab = document.querySelector('.hero-tab.active')
  if (activeTab) moveSlider(activeTab)

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab

      tabs.forEach((t) => t.classList.remove('active'))
      tab.classList.add('active')
      moveSlider(tab)

      panels.forEach((panel) => {
        const isTarget = panel.id === `panel-${target}`
        if (isTarget) {
          panel.classList.add('active')
          panel.querySelectorAll('[data-animate]').forEach((el) => {
            el.classList.remove('visible')
            requestAnimationFrame(() => {
              requestAnimationFrame(() => el.classList.add('visible'))
            })
          })
        } else {
          panel.classList.remove('active')
        }
      })
    })
  })

  // Recalculate on resize
  window.addEventListener('resize', () => {
    const current = document.querySelector('.hero-tab.active')
    if (current) moveSlider(current)
  })
</script>
