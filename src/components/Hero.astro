---
import '../components/Hero.css'
---

<section id="inicio" class="hero-section">
  <div class="hero-bg">
    <img
      class="hero-bg-image"
      src="/images/hero-bg.webp"
      alt=""
      aria-hidden="true"
      width="1920"
      height="932"
    />
    <div class="hero-overlay"></div>
    <div class="hero-gradient-1"></div>
    <div class="hero-gradient-2"></div>
    <div class="hero-grid"></div>
  </div>

  <div class="hero-content" style="animation: fadeUp 0.8s ease-out both;">
    <span class="hero-tag" style="animation: fadeUp 0.6s ease-out 0.2s both;">
      Real Estate Investment
    </span>

    <h1 class="hero-title" style="animation: fadeUp 0.7s ease-out 0.4s both;">
      Inversión inmobiliaria{' '}
      <span class="highlight">inteligente</span>
    </h1>

    <p class="hero-description" style="animation: fadeUp 0.6s ease-out 0.6s both;">
      En Hom Estate, nos especializamos en optimizar el rendimiento de sus
      activos inmobiliarios a través de estrategias avanzadas y un enfoque
      integral.
    </p>

    <a
      href="#servicios"
      class="hero-cta"
      style="animation: scaleIn 0.5s ease-out 0.8s both;"
    >
      Descubre más
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
    </a>
  </div>

  <div class="hero-scroll-indicator" aria-hidden="true">
    <span>Scroll</span>
    <div class="hero-scroll-line"></div>
  </div>
</section>
