  'habitacion_cama_rayas_verdes_detalle_cuadro_abstracto.jpeg',
  'habitacion_cama_rayas_verdes_espejo_puerta_abierta.jpeg',
  'habitacion_cama_lila_cuadro_arco_marron_escritorio_armario.jpeg',
  'habitacion_cama_lila_cuadro_arco_marron_escritorio_ventana.jpeg',
  'habitacion_cama_lila_cuadro_arco_marron_espejo_puerta.jpeg',
