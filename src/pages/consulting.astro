---
import BaseLayout from '../layouts/BaseLayout.astro'
import PageHero from '../components/PageHero.astro'
import './pages.css'

const SERVICES = [
  { title: 'Analisis de Mercado', description: 'Estudio exhaustivo del mercado inmobiliario para identificar las mejores oportunidades de inversion en cada zona.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>' },
  { title: 'Estrategia de Inversion', description: 'Diseno de estrategias personalizadas para maximizar la rentabilidad de su cartera inmobiliaria.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>' },
  { title: 'Due Diligence', description: 'Analisis detallado de cada activo: estado legal, tecnico y financiero antes de la adquisicion.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m9 15 2 2 4-4"/></svg>' },
  { title: 'Optimizacion Fiscal', description: 'Estructuracion fiscal eficiente para maximizar el retorno neto de sus inversiones inmobiliarias.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="16" x="4" y="4" rx="2"/><path d="M4 10h16"/><path d="M10 4v16"/></svg>' },
]
---

<BaseLayout>
  <PageHero
    title="Consultoria de Inversion Inmobiliaria"
    breadcrumbs={[{ label: 'Consulting' }]}
    image="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1200&fm=webp"
  />

  <section class="page-section">
    <div class="page-container">
      <div class="page-section-header" data-animate>
        <h2 class="section-title">Nuestros Servicios de Consultoria</h2>
        <p class="section-subtitle">
          Acompanamos a inversores y propietarios en cada fase del proceso inmobiliario,
          desde el analisis inicial hasta la optimizacion de la rentabilidad.
        </p>
      </div>

      <div class="services-grid-4">
        {SERVICES.map((service, i) => (
          <div class="service-card" data-animate data-delay={String(i + 1)}>
            <div class="service-card-icon" set:html={service.icon} />
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="page-section page-section-dark">
    <div class="page-container page-cta-block">
      <h2 data-animate>Maximice su rentabilidad inmobiliaria</h2>
      <p data-animate data-delay="1">Contacte con nuestro equipo de expertos para una consulta personalizada sin compromiso.</p>
      <a href="tel:+34636155847" class="btn-primary" data-animate="scale" data-delay="2">
        Solicitar consulta
      </a>
    </div>
  </section>
</BaseLayout>
