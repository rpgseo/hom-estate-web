---
import BaseLayout from '../layouts/BaseLayout.astro'
import PageHero from '../components/PageHero.astro'
import './pages.css'

const STEPS = [
  { number: '01', title: 'Analisis', description: 'Evaluamos el inmueble, identificamos necesidades y definimos el alcance del proyecto con un presupuesto detallado.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>' },
  { number: '02', title: 'Diseno', description: 'Nuestro equipo de diseno crea propuestas personalizadas que maximizan el valor y la funcionalidad del espacio.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9.06 11.9 8.07-8.06a2.85 2.85 0 1 1 4.03 4.03l-8.06 8.08"/><path d="M7.07 14.94c-1.66 0-3 1.35-3 3.02 0 1.33-2.5 1.52-2 2.02 1.08 1.1 2.49 2.02 4 2.02 2.2 0 4-1.8 4-4.04a3.01 3.01 0 0 0-3-3.02z"/></svg>' },
  { number: '03', title: 'Ejecucion', description: 'Gestion integral de la obra con supervision constante, cumpliendo plazos y estandares de calidad.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 12-8.5 8.5c-.83.83-2.17.83-3 0 0 0 0 0 0 0a2.12 2.12 0 0 1 0-3L12 9"/><path d="M17.64 15 22 10.64"/><path d="m20.91 11.7-1.25-1.25c-.6-.6-.93-1.4-.93-2.25v-.86L16.01 4.6a5.56 5.56 0 0 0-3.94-1.64H9l.92.82A6.18 6.18 0 0 1 12 8.4v1.56l2 2h2.47l2.26 1.91"/></svg>' },
  { number: '04', title: 'Entrega', description: 'Entrega llave en mano con revision final, documentacion completa y garantia de satisfaccion.', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>' },
]
---

<BaseLayout>
  <PageHero
    title="Reformas Integrales"
    breadcrumbs={[{ label: 'Reformas' }]}
    image="https://images.unsplash.com/photo-1503387762-592deb58ef4e?w=1200&fm=webp"
  />

  <section class="page-section">
    <div class="page-container">
      <div class="page-section-header" data-animate>
        <h2 class="section-title">Transformamos espacios</h2>
        <p class="section-subtitle">
          Reformas integrales orientadas a maximizar el valor de su propiedad,
          con un enfoque en calidad, funcionalidad y rentabilidad.
        </p>
      </div>

      <div class="reformas-before-after">
        <div class="ba-card" data-animate="slide-left">
          <img src="https://images.unsplash.com/photo-1484154218962-a197022b5858?w=600&fm=webp" alt="Antes de la reforma" width="600" height="400" loading="lazy" />
          <span class="ba-label">Antes</span>
        </div>
        <div class="ba-card" data-animate="slide-right">
          <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=600&fm=webp" alt="Despues de la reforma" width="600" height="400" loading="lazy" />
          <span class="ba-label">Despues</span>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section page-section-light">
    <div class="page-container">
      <div class="page-section-header" data-animate>
        <h2 class="section-title">Nuestro Proceso</h2>
      </div>

      <div class="steps-grid">
        {STEPS.map((step, i) => (
          <div class="step-card" data-animate data-delay={String(i + 1)}>
            <span class="step-number">{step.number}</span>
            <div class="step-icon" set:html={step.icon} />
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="page-section page-section-dark">
    <div class="page-container page-cta-block">
      <h2 data-animate>Solicite su presupuesto sin compromiso</h2>
      <p data-animate data-delay="1">Nuestro equipo evaluara su proyecto y le proporcionara un presupuesto detallado.</p>
      <a href="tel:+34636155847" class="btn-primary" data-animate="scale" data-delay="2">
        Contactar ahora
      </a>
    </div>
  </section>
</BaseLayout>
